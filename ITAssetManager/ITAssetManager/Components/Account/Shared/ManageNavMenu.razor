@using Microsoft.AspNetCore.Identity


@inject SignInManager<ApplicationUser> SignInManager

<ul class="nav nav-pills flex-column">
    <li class="nav-item">
        <NavLink class="nav-link" href="Account/Manage" Match="NavLinkMatch.All">프로필</NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="Account/Manage/Email">이메일</NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="Account/Manage/ChangePassword">비밀번호</NavLink>
    </li>
    @if (hasExternalLogins)
    {
        <li class="nav-item">
            <NavLink class="nav-link" href="Account/Manage/ExternalLogins">외부 서비스 로그인</NavLink>
        </li>
    }
    @* <li class="nav-item">
        <NavLink class="nav-link" href="Account/Manage/TwoFactorAuthentication">이중인증</NavLink>
    </li>*@
    <li class="nav-item">
        <NavLink class="nav-link" href="Account/Manage/PersonalData">개인정보</NavLink>
    </li> 
</ul>

@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }
}
