@page "/Error"
@using System.Diagnostics

<PageTitle>오류</PageTitle>

<h1 class="text-danger">오류.</h1>
<h2 class="text-danger">요청을 처리하는 동안 오류가 발생했습니다.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>요청 ID:</strong> <code>@RequestId</code>
    </p>
}

<h3>개발 모드</h3>
<p>
    <strong>개발</strong> 환경으로 전환하면 발생한 오류에 대한 자세한 정보가 표시됩니다.
</p>
<p>
    <strong>배포된 애플리케이션에 대해 개발 환경을 활성화해서는 안 됩니다.</strong>
    최종 사용자에게 예외로부터 민감한 정보가 표시될 수 있습니다.
    로컬 디버깅의 경우 <strong>ASPNETCORE_ENVIRONMENT</strong> 환경 변수를 <strong>개발</strong>로 설정하고 앱을 다시 시작하여 <strong>개발</strong> 환경을 활성화합니다.
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
