@using Blazorise
@using Blazorise.Components
@inherits LayoutComponentBase

<MainLayoutTemplate>
    <SidebarContent>
        <NavMenu @rendermode="InteractiveAuto" />
    </SidebarContent>
    <ChildContent>
        @Body
    </ChildContent>
</MainLayoutTemplate>

<MessageProvider @rendermode="InteractiveAuto" />
<ModalProvider @rendermode="InteractiveAuto" />
<NotificationProvider @rendermode="InteractiveAuto" />
<PageProgressProvider @rendermode="InteractiveAuto" />
<ToastProvider @rendermode="InteractiveAuto" />