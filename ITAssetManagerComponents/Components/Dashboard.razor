<HeaderTitle Title="@HeaderConstant.DashboardTitle" />

<Grid>
    <Column ColumnSize="ColumnSize.IsHalf.OnWidescreen.IsFull">
        <BaseLineChart Title="서비스 가동률"
                       XAxisLabel="월"
                       YAxisLabel="%"
                       SuggestedMin="90"
                       SuggestedMax="100"
                       BackgroundColor="@ChartColor.FromRgba(54, 162, 235, 0.2f)"
                       BorderColor="@ChartColor.FromRgba(54, 162, 235, 1f)"
                       GetValue="@(sla => (int)(sla.UptimeRate * 100.0))" />
    </Column>
    <Column ColumnSize="ColumnSize.IsHalf.OnWidescreen.IsFull">
        <BaseLineChart Title="장애적기 처리시간"
                       XAxisLabel="월"
                       YAxisLabel="평균시간"
                       SuggestedMin="0"
                       SuggestedMax="12"
                       BackgroundColor="@ChartColor.FromRgba(255, 99, 132, 0.2f)"
                       BorderColor="@ChartColor.FromRgba(255, 99, 132, 1f)"
                       GetValue="@(sla => (int)(sla.DisabilityHoursAverage))" />
    </Column>
    <Column ColumnSize="ColumnSize.IsHalf.OnWidescreen.IsFull">
        <BaseLineChart Title="기술지원요청 완료율"
                       XAxisLabel="월"
                       YAxisLabel="%"
                       SuggestedMin="85"
                       SuggestedMax="100"
                       BackgroundColor="@ChartColor.FromRgba(255, 206, 86, 0.2f)"
                       BorderColor="@ChartColor.FromRgba(255, 206, 86, 1f)"
                       GetValue="@(sla => (int)(sla.TechnicalSupportCompletionRate * 100.0))" />
    </Column>
    <Column ColumnSize="ColumnSize.IsHalf.OnWidescreen.IsFull">
        <BaseLineChart Title="정기점검 준수율"
                       XAxisLabel="월"
                       YAxisLabel="%"
                       SuggestedMin="85"
                       SuggestedMax="100"
                       BackgroundColor="@ChartColor.FromRgba(75, 192, 192, 0.2f)"
                       BorderColor="@ChartColor.FromRgba(75, 192, 192, 1f)"
                       GetValue="@(sla => (int)(sla.RoutineCheckRate * 100.0))" />
    </Column>
    <Column ColumnSize="ColumnSize.IsHalf.OnWidescreen.IsFull">
        <BaseLineChart Title="보안 취약건"
                       XAxisLabel="월"
                       YAxisLabel="건"
                       SuggestedMin="0"
                       SuggestedMax="10"
                       BackgroundColor="@ChartColor.FromRgba(153, 102, 255, 0.2f)"
                       BorderColor="@ChartColor.FromRgba(153, 102, 255, 1f)"
                       GetValue="@(sla => (int)(sla.SecurityIssues))" />
    </Column>
    <Column ColumnSize="ColumnSize.IsHalf.OnWidescreen.IsFull">
        <BaseLineChart Title="SLA 평가점수 합산현황"
                       XAxisLabel="월"
                       YAxisLabel="점"
                       SuggestedMin="0"
                       SuggestedMax="100"
                       BackgroundColor="@ChartColor.FromRgba(255, 159, 64, 0.2f)"
                       BorderColor="@ChartColor.FromRgba(255, 159, 64, 1f)"
                       GetValue="@GetSLAScore" />
    </Column>
</Grid>

@code {
    private int GetSLAScore(ServiceLevelAgreement sla)
    {
        return (int)(sla.TechnicalSupportLevel) +
            (int)(sla.RoutineCheckLevel) +
            (int)(sla.SecurityIssuesLevel) +
            (int)(sla.UptimeLevel) +
            (int)(sla.DisabilityHoursLevel);
    }
}
