@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider

<Scheduler TItem="UserAppointmentModel" @bind-Date="@selectedDate"
           Data="@appointments"
           @bind-SelectedView="@selectedView"
           Editable
           Draggable
           SlotSelectionMode="SchedulerSlotSelectionMode.Mouse">
    <SchedulerToolbar />
    <SchedulerViews>
        <SchedulerDayView StartTime="@startTime" EndTime="@endTime" WorkDayStart="@workDayStart" WorkDayEnd="@workDayEnd" />
        <SchedulerWeekView StartTime="@startTime" EndTime="@endTime" WorkDayStart="@workDayStart" WorkDayEnd="@workDayEnd" />
        <SchedulerWorkWeekView StartTime="@startTime" EndTime="@endTime" WorkDayStart="@workDayStart" WorkDayEnd="@workDayEnd" />
        <SchedulerMonthView StartTime="@startTime" EndTime="@endTime" WorkDayStart="@workDayStart" WorkDayEnd="@workDayEnd" />
    </SchedulerViews>
</Scheduler>

@code {
    private DateOnly selectedDate = DateOnly.FromDateTime(DateTime.Today);
    private SchedulerView selectedView = SchedulerView.Week;
    private TimeOnly startTime = new TimeOnly(6, 0);
    private TimeOnly endTime = new TimeOnly(22, 0);
    private TimeOnly workDayStart = new TimeOnly(8, 0);
    private TimeOnly workDayEnd = new TimeOnly(18, 0);

    private List<UserAppointmentModel> appointments = new();
    private string? currentUserId;

    public class UserAppointmentModel
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public bool AllDay { get; set; }
        public string? RecurrenceRule { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        
        if (!string.IsNullOrEmpty(currentUserId))
        {
            await LoadUserAppointments();
        }
        else
        {
            // Load some sample data for demo when no user is authenticated
            LoadSampleData();
        }
    }

    private async Task LoadUserAppointments()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        try
        {
            using var context = DbFactory.CreateDbContext();
            var userAppointments = await context.UserAppointments
                .Where(a => a.UserId == currentUserId)
                .ToListAsync();

            appointments = userAppointments.Select(ua => new UserAppointmentModel
            {
                Id = ua.Id.ToString(),
                Title = ua.Title,
                Description = ua.Description,
                Start = ua.Start,
                End = ua.End,
                AllDay = ua.AllDay,
                RecurrenceRule = ua.RecurrenceRule
            }).ToList();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            // Handle database errors gracefully
            Console.WriteLine($"Error loading appointments: {ex.Message}");
            LoadSampleData();
        }
    }

    private void LoadSampleData()
    {
        var today10AM = DateTime.Today.AddHours(10);
        
        appointments = new List<UserAppointmentModel>
        {
            new UserAppointmentModel
            {
                Id = "sample1",
                Title = "IT 자산 관리 회의",
                Description = "월간 IT 자산 관리 현황 점검 회의",
                Start = today10AM,
                End = today10AM.AddHours(1)
            },
            new UserAppointmentModel
            {
                Id = "sample2", 
                Title = "서버 점검",
                Description = "정기 서버 상태 점검 및 유지보수",
                Start = today10AM.AddDays(-2).AddHours(2),
                End = today10AM.AddDays(-2).AddHours(3)
            },
            new UserAppointmentModel
            {
                Id = "sample3",
                Title = "보안 취약점 점검",
                Description = "주간 보안 취약점 점검 및 패치 적용",
                Start = today10AM.AddDays(1).AddHours(-2),
                End = today10AM.AddDays(1).AddHours(-1),
                RecurrenceRule = "FREQ=WEEKLY;BYDAY=TU;INTERVAL=1;COUNT=4"
            }
        };
    }

    public async Task SaveAppointmentAsync(UserAppointmentModel appointment)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        try
        {
            using var context = DbFactory.CreateDbContext();
            
            var userAppointment = new UserAppointment
            {
                Title = appointment.Title,
                Description = appointment.Description,
                Start = appointment.Start,
                End = appointment.End,
                AllDay = appointment.AllDay,
                RecurrenceRule = appointment.RecurrenceRule,
                UserId = currentUserId
            };

            context.UserAppointments.Add(userAppointment);
            await context.SaveChangesAsync();
            
            await LoadUserAppointments();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving appointment: {ex.Message}");
        }
    }
}
