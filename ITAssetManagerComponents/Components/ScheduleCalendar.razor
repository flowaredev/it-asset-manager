@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using Blazorise.Scheduler
@using Blazorise.Localization
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
<HeaderTitle Title="@HeaderConstant.SecheduleCalendarTitle" />

<Scheduler TItem="UserAppointmentModel" @bind-Date="@selectedDate"
           Data="@appointments"
           @bind-SelectedView="@selectedView"
           Editable
           Draggable
           Localizers="@schedulerLocalizers"
           SlotSelectionMode="SchedulerSlotSelectionMode.Mouse"
           ItemInserted="@OnAppointmentInserted"
           ItemUpdated="@OnAppointmentUpdated"
           ItemRemoved="@OnAppointmentRemoved">
    <SchedulerToolbar />
    <SchedulerViews>
        <SchedulerDayView StartTime="@startTime" EndTime="@endTime" WorkDayStart="@workDayStart" WorkDayEnd="@workDayEnd" />
        <SchedulerWeekView StartTime="@startTime" EndTime="@endTime" WorkDayStart="@workDayStart" WorkDayEnd="@workDayEnd" />
        <SchedulerWorkWeekView StartTime="@startTime" EndTime="@endTime" WorkDayStart="@workDayStart" WorkDayEnd="@workDayEnd" />
        <SchedulerMonthView StartTime="@startTime" EndTime="@endTime" WorkDayStart="@workDayStart" WorkDayEnd="@workDayEnd" />
    </SchedulerViews>
</Scheduler>

@code {
    private DateOnly selectedDate = DateOnly.FromDateTime(DateTime.Today);
    private SchedulerView selectedView = SchedulerView.Week;
    private TimeOnly startTime = new TimeOnly(6, 0);
    private TimeOnly endTime = new TimeOnly(22, 0);
    private TimeOnly workDayStart = new TimeOnly(8, 0);
    private TimeOnly workDayEnd = new TimeOnly(18, 0);

    private List<UserAppointmentModel> appointments = new();
    private string? currentUserId;

    // Korean localization for Scheduler
    private SchedulerLocalizers schedulerLocalizers = new SchedulerLocalizers
    {
        NewLocalizer = (localizer, arguments) => "새로 만들기",
        EditLocalizer = (localizer, arguments) => "수정",
        TitleLocalizer = (localizer, arguments) => "제목",
        StartLocalizer = (localizer, arguments) => "시작",
        EndLocalizer = (localizer, arguments) => "종료",
        AllDayLocalizer = (localizer, arguments) => "종일",
        DescriptionLocalizer = (localizer, arguments) => "설명",
        DeleteLocalizer = (localizer, arguments) => "삭제",
        CancelLocalizer = (localizer, arguments) => "취소",
        SaveLocalizer = (localizer, arguments) => "저장",
        ItemDeleteConfirmationLocalizer = (localizer, arguments) => "이 일정을 삭제하시겠습니까?",
        OccurrenceDeleteConfirmationLocalizer = (localizer, arguments) => "이 일정만 삭제하시겠습니까?",
        SeriesDeleteConfirmationTextLocalizer = (localizer, arguments) => "전체 시리즈를 삭제하시겠습니까?",
        DeleteSeriesLocalizer = (localizer, arguments) => "시리즈 삭제",
        DeleteOccurrenceLocalizer = (localizer, arguments) => "이 일정만 삭제",
        EditSeriesLocalizer = (localizer, arguments) => "시리즈 수정",
        EditOccurrenceLocalizer = (localizer, arguments) => "이 일정만 수정",
        AppointmentLocalizer = (localizer, arguments) => "일정",
        TodayLocalizer = (localizer, arguments) => "오늘",
        PreviousLocalizer = (localizer, arguments) => "이전",
        NextLocalizer = (localizer, arguments) => "다음",
        DayLocalizer = (localizer, arguments) => "일",
        WeekLocalizer = (localizer, arguments) => "주",
        WorkWeekLocalizer = (localizer, arguments) => "근무주",
        MonthLocalizer = (localizer, arguments) => "월",
        YearLocalizer = (localizer, arguments) => "년",
        OnLocalizer = (localizer, arguments) => "시",
        WeekOfMonthLocalizer = (localizer, arguments) => "월의 주",
        DayOfWeekLocalizer = (localizer, arguments) => "요일",
        MonthOfYearLocalizer = (localizer, arguments) => "년의 월",
        CountLocalizer = (localizer, arguments) => "횟수",
        NeverLocalizer = (localizer, arguments) => "없음",
        RepeatEveryLocalizer = (localizer, arguments) => "반복 간격",
        WhatDoYouWantToDoLocalizer = (localizer, arguments) => "어떻게 하시겠습니까?",
        RecurringSeriesWhatDoYouWantToDoLocalizer = (localizer, arguments) => "이 항목은 반복 시리즈입니다. 어떻게 하시겠습니까?",
        StartDateHigherValidationLocalizer = (localizer, arguments) => "시작 날짜가 종료 날짜보다 늦을 수 없습니다.",
        StartDateHigherOrEqualValidationLocalizer = (localizer, arguments) => "시작 날짜가 종료 날짜보다 늦거나 같을 수 없습니다.",
        EndDateLowerValidationLocalizer = (localizer, arguments) => "종료 날짜가 시작 날짜보다 빠를 수 없습니다.",
        EndDateLowerOrEqualValidationLocalizer = (localizer, arguments) => "종료 날짜가 시작 날짜보다 빠르거나 같을 수 없습니다.",
        EndTimeLowerValidationLocalizer = (localizer, arguments) => "종료 시간이 시작 시간보다 빠를 수 없습니다.",
        TitleRequiredValidationLocalizer = (localizer, arguments) => "제목은 필수입니다."
    };

    public class UserAppointmentModel
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public bool AllDay { get; set; }
        public string? RecurrenceRule { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(currentUserId))
        {
            await LoadUserAppointments();
        }
    }

    private async Task LoadUserAppointments()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        try
        {
            using var context = DbFactory.CreateDbContext();
            var userAppointments = await context.UserAppointments
                .Where(a => a.UserId == currentUserId)
                .ToListAsync();

            appointments = userAppointments.Select(ua => new UserAppointmentModel
            {
                Id = ua.Id.ToString(),
                Title = ua.Title,
                Description = ua.Description,
                Start = ua.Start,
                End = ua.End,
                AllDay = ua.AllDay,
                RecurrenceRule = ua.RecurrenceRule
            }).ToList();

        }
        catch (Exception ex)
        {
            // Handle database errors gracefully
            Debug.WriteLine($"Error loading appointments: {ex.Message}");
        }
    }

    // Event handlers for Blazorise Scheduler events
    private async Task OnAppointmentInserted(SchedulerInsertedItem<UserAppointmentModel> item)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        await InsertAppointmentAsync(item.Item);
    }

    private async Task OnAppointmentUpdated(SchedulerUpdatedItem<UserAppointmentModel> item)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        await UpdateAppointmentAsync(item.NewItem);
    }

    private async Task OnAppointmentRemoved(SchedulerUpdatedItem<UserAppointmentModel> item)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        await RemoveAppointmentAsync(item.OldItem);
    }

    // Helper method to save an appointment to the database
    private async Task InsertAppointmentAsync(UserAppointmentModel appointment)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        try
        {
            using var context = DbFactory.CreateDbContext();

            var userAppointment = new UserAppointment
            {
                Title = appointment.Title ?? "새 일정",
                Description = appointment.Description ?? string.Empty,
                Start = appointment.Start,
                End = appointment.End,
                AllDay = appointment.AllDay,
                RecurrenceRule = appointment.RecurrenceRule,
                UserId = currentUserId
            };

            context.UserAppointments.Add(userAppointment);
            await context.SaveChangesAsync();

            Debug.WriteLine($"일정이 저장되었습니다: {appointment.Title}");
            await LoadUserAppointments(); // Ensure it waits for the loading to complete
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"일정 저장 중 오류 발생: {ex.Message}");
        }
    }

    // Helper method to update an appointment in the database
    private async Task UpdateAppointmentAsync(UserAppointmentModel appointment)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        try
        {
            using var context = DbFactory.CreateDbContext();
            
            if (int.TryParse(appointment.Id, out int appointmentId))
            {
                var userAppointment = await context.UserAppointments
                    .FirstOrDefaultAsync(a => a.Id == appointmentId && a.UserId == currentUserId);

                if (userAppointment != null)
                {
                    userAppointment.Title = appointment.Title ?? "일정";
                    userAppointment.Description = appointment.Description ?? string.Empty;
                    userAppointment.Start = appointment.Start;
                    userAppointment.End = appointment.End;
                    userAppointment.AllDay = appointment.AllDay;
                    userAppointment.RecurrenceRule = appointment.RecurrenceRule;

                    await context.SaveChangesAsync();
                    
                    Debug.WriteLine($"일정이 수정되었습니다: {appointment.Title} (ID: {appointment.Id})");
                }
                else
                {
                    Debug.WriteLine($"수정할 일정을 찾을 수 없습니다: ID {appointment.Id}");
                }
            }
            else
            {
                Debug.WriteLine($"잘못된 일정 ID 형식: {appointment.Id}");
            }
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"일정 수정 중 오류 발생: {ex.Message}");
        }
    }

    // Helper method to remove an appointment from the database
    private async Task RemoveAppointmentAsync(UserAppointmentModel appointment)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        try
        {
            using var context = DbFactory.CreateDbContext();
            
            if (int.TryParse(appointment.Id, out int appointmentId))
            {
                var userAppointment = await context.UserAppointments
                    .FirstOrDefaultAsync(a => a.Id == appointmentId && a.UserId == currentUserId);

                if (userAppointment != null)
                {
                    context.UserAppointments.Remove(userAppointment);
                    await context.SaveChangesAsync();
                    
                    Debug.WriteLine($"일정이 삭제되었습니다: {appointment.Title} (ID: {appointment.Id})");
                }
                else
                {
                    Debug.WriteLine($"삭제할 일정을 찾을 수 없습니다: ID {appointment.Id}");
                }
            }
            else
            {
                Debug.WriteLine($"잘못된 일정 ID 형식: {appointment.Id}");
            }
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"일정 삭제 중 오류 발생: {ex.Message}");
        }
    }
}
