@inject IDbContextFactory<ApplicationDbContext> DbFactory
<HeaderTitle Title="@HeaderConstant.SecurityEquipmentTitle" />

<CommonAssetDataGrid OnUpdateItems=@UpdateAssets
                     OnSaveItem=@SaveAsset
                     OnDeleteItem=@DeleteAsset
                     OnShowDetail="@ShowDetailView" />

@if (_modalVisible)
{
    <Modal @bind-Visible="@_modalVisible">
        <ModalContent Centered="true" Scrollable="true" Size="ModalSize.Fullscreen">
            <ModalHeader>
                <ModalTitle>보안 장비 사양</ModalTitle>
                <CloseButton Margin="Margin.Is2.FromEnd" />
            </ModalHeader>
            <ModalBody>
                <BaseDataGrid TItem="SecurityDevice"
                              OnUpdateItems=@UpdateSecurityDevices
                              OnSaveItem="@SaveSecurityDevice"
                              OnDeleteItem="@DeleteSecurityDevice">
                    <DataGridColumn Field="@nameof(SecurityDevice.Manufacturer)" Caption="제조사" Editable="true" Width="200px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.Manufacturer</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(SecurityDevice.Model)" Caption="모델명" Editable="true" Width="200px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.Model</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(SecurityDevice.SerialNumber)" Caption="시리얼번호" Editable="true" Width="200px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.SerialNumber</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(SecurityDevice.DeviceSpec)" Caption="장비 SPEC" Editable="true" Width="250px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.DeviceSpec</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(SecurityDevice.IpAddress)" Caption="IP" Editable="true" Width="160px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.IpAddress</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(SecurityDevice.Rack)" Caption="랙 위치" Editable="true" Width="150px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.Rack</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridNumericColumn Field="@nameof(SecurityDevice.UnitSize)" Caption="U" Editable="true" Width="80px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.UnitSize</Div>
                        </DisplayTemplate>
                    </DataGridNumericColumn>
                    <DataGridColumn Field="@nameof(SecurityDevice.Notes)" Caption="비고" Editable="true" Width="250px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.Notes</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                </BaseDataGrid>
            </ModalBody>
        </ModalContent>
    </Modal>
}

@code {
    private bool _modalVisible;
    private CommonAsset _selectedAsset = new();

    private async Task<List<CommonAsset>> UpdateAssets()
    {
        using var context = DbFactory.CreateDbContext();
        var items = await context.SecurityEquipments
            .Include(s => s.CommonAsset)
            .Select(s => s.CommonAsset)
            .ToListAsync();
        return items;
    }

    private async Task SaveAsset(CommonAsset asset)
    {
        using var context = DbFactory.CreateDbContext();

        if (asset.Id == 0)
        {
            asset.SecurityEquipment = new SecurityEquipment()
                {
                    CommonAssetId = asset.Id,
                    CommonAsset = asset
                };

            await context.CommonAssets.AddAsync(asset);
        }
        else
        {
            context.CommonAssets.Update(asset);
        }

        await context.SaveChangesAsync();
    }

    private async Task DeleteAsset(CommonAsset asset)
    {
        using var context = DbFactory.CreateDbContext();
        context.CommonAssets.Remove(asset);
        await context.SaveChangesAsync();
    }

    private async Task ShowDetailView(CommonAsset asset)
    {
        _selectedAsset = asset;
        _modalVisible = true;
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task<List<SecurityDevice>> UpdateSecurityDevices()
    {
        using var context = DbFactory.CreateDbContext();
        var items = await context.SecurityEquipments
            .Where(s => s.CommonAssetId == _selectedAsset.Id)
            .Include(s => s.SecurityDevices)
            .SelectMany(s => s.SecurityDevices)
            .ToListAsync();
        return items;
    }

    private async Task SaveSecurityDevice(SecurityDevice device)
    {
        using var context = DbFactory.CreateDbContext();

        if (device.Id == 0)
        {
            Debug.Assert(_selectedAsset.Id != 0);

            var equipment = await context.SecurityEquipments
                .SingleAsync(s => s.CommonAssetId == _selectedAsset.Id);

            device.SecurityEquipmentId = equipment.Id;
            context.SecurityDevices.Add(device);
        }
        else
        {
            context.SecurityDevices.Update(device);
        }

        await context.SaveChangesAsync();
    }

    private async Task DeleteSecurityDevice(SecurityDevice device)
    {
        using var context = DbFactory.CreateDbContext();
        context.SecurityDevices.Remove(device);
        await context.SaveChangesAsync();
    }
}
