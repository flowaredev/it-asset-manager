@using System.Security.Claims
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IMessageService MessageService

<HeaderTitle Title="@Title" />

<Field Margin="Margin.Is2.OnY">
    <FieldLabel>문서 내용</FieldLabel>
    <FieldBody>
        <MemoEdit @bind-Text="_content" Rows="4" Placeholder="문서 내용을 입력하세요." />
    </FieldBody>
</Field>

<Button Color="Color.Primary" Clicked="SaveAsync">저장</Button>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <Alert Margin="Margin.Is2.FromTop" Color="@_statusColor" Visible="true">
        @_statusMessage
    </Alert>
}

@if (_documents.Count > 0)
{
    <Field Margin="Margin.Is4.FromTop">
        <FieldLabel>문서 내용 목록</FieldLabel>
    </Field>

    <div class="mt-2">
        @foreach (var document in _documents)
        {
            var documentComments = GetCommentsForDocument(document.Id);

            <Card Margin="Margin.Is2.FromBottom">
                <CardBody>
                    <Text>@document.Content</Text>
                    <Text TextColor="TextColor.Secondary" TextSize="TextSize.ExtraSmall">
                        @document.UpdatedAt.ToString("yyyy-MM-dd HH:mm")
                    </Text>
                    <Text TextColor="TextColor.Secondary" TextSize="TextSize.ExtraSmall">
                        작성자: @FormatAuthor(document.AuthorUserName, document.AuthorName)
                    </Text>

                    @if (_isAdministrator)
                    {
                        <Button Margin="Margin.Is2.FromTop.Is2.FromStart"
                                Color="Color.Danger"
                                Size="Size.Small"
                                Clicked="@(async () => await DeleteDocumentAsync(document.Id))">문서 삭제</Button>
                    }

                    <Field Margin="Margin.Is3.FromTop">
                        <FieldLabel>댓글</FieldLabel>
                        <FieldBody>
                            <MemoEdit Text="@GetCommentInput(document.Id)"
                                      TextChanged="@(value => SetCommentInput(document.Id, value))"
                                      Rows="3"
                                      Placeholder="댓글을 입력하세요." />
                        </FieldBody>
                    </Field>

                    <Button Color="Color.Info" Size="Size.Small" Clicked="@(async () => await AddCommentAsync(document.Id))">댓글 추가</Button>

                    @if (documentComments.Count > 0)
                    {
                        <Field Margin="Margin.Is3.FromTop">
                            <FieldLabel>댓글 목록</FieldLabel>
                        </Field>

                        <div class="mt-2">
                            @foreach (var comment in documentComments)
                            {
                                <Card Margin="Margin.Is2.FromBottom">
                                    <CardBody>
                                        <Text>@comment.Comment</Text>
                                        <Text TextColor="TextColor.Secondary" TextSize="TextSize.ExtraSmall">
                                            @comment.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                                        </Text>
                                        <Text TextColor="TextColor.Secondary" TextSize="TextSize.ExtraSmall">
                                            작성자: @FormatAuthor(comment.AuthorUserName, comment.AuthorName)
                                        </Text>

                                        @if (_isAdministrator)
                                        {
                                            <Button Margin="Margin.Is2.FromTop.Is2.FromStart"
                                                    Color="Color.Danger"
                                                    Size="Size.ExtraSmall"
                                                    Clicked="@(async () => await DeleteCommentAsync(comment.Id))">댓글 삭제</Button>
                                        }
                                    </CardBody>
                                </Card>
                            }
                        </div>
                    }
                </CardBody>
            </Card>
        }
    </div>

    <Field Margin="Margin.Is3.FromTop">
        <FieldBody>
            <Button Color="Color.Secondary"
                    Size="Size.Small"
                    Disabled="@(_currentPage <= 1)"
                    Clicked="@(async () => await ChangePageAsync(_currentPage - 1))">이전</Button>
            <Text Margin="Margin.Is2.FromStart.Is2.FromEnd">@_currentPage / @TotalPages</Text>
            <Button Color="Color.Secondary"
                    Size="Size.Small"
                    Disabled="@(_currentPage >= TotalPages)"
                    Clicked="@(async () => await ChangePageAsync(_currentPage + 1))">다음</Button>
        </FieldBody>
    </Field>
}

@code {
    [Parameter, EditorRequired]
    public string DocumentType { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    private const int PageSize = 10;

    private string _content = string.Empty;
    private string _statusMessage = string.Empty;
    private Color _statusColor = Color.Success;
    private int _currentPage = 1;
    private int _totalDocumentsCount;
    private bool _isAdministrator;
    private string? _currentUserName;
    private string? _currentDisplayName;
    private List<OperationDocument> _documents = new();
    private List<OperationDocumentComment> _comments = new();
    private Dictionary<int, List<OperationDocumentComment>> _commentsByDocument = new();
    private readonly Dictionary<int, string> _commentInputs = new();

    private int TotalPages => _totalDocumentsCount == 0 ? 1 : (int)Math.Ceiling((double)_totalDocumentsCount / PageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserAsync();
        await LoadDocumentsAsync();
        await LoadCommentsAsync();
    }

    private async Task LoadCurrentUserAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _isAdministrator = user.IsInRole(RoleConstants.Administrator);
        _currentUserName = user.Identity?.Name;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            _currentDisplayName = null;
            return;
        }

        using var context = DbFactory.CreateDbContext();
        _currentDisplayName = await context.Users
            .Where(u => u.Id == userId)
            .Select(u => u.Name)
            .FirstOrDefaultAsync();
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_content))
        {
            _statusColor = Color.Danger;
            _statusMessage = "문서 내용을 입력하세요.";
            return;
        }

        using var context = DbFactory.CreateDbContext();
        var document = new OperationDocument
        {
            DocumentType = DocumentType,
            Content = _content.Trim(),
            UpdatedAt = TimeZoneHelper.GetKoreaTimeNow(),
            AuthorUserName = _currentUserName,
            AuthorName = _currentDisplayName
        };

        context.OperationDocuments.Add(document);
        await context.SaveChangesAsync();

        _content = string.Empty;
        _currentPage = 1;
        _statusColor = Color.Success;
        _statusMessage = "저장되었습니다.";

        await LoadDocumentsAsync();
        await LoadCommentsAsync();
    }

    private async Task AddCommentAsync(int operationDocumentId)
    {
        var inputComment = GetCommentInput(operationDocumentId);

        if (string.IsNullOrWhiteSpace(inputComment))
        {
            _statusColor = Color.Danger;
            _statusMessage = "댓글을 입력하세요.";
            return;
        }

        using var context = DbFactory.CreateDbContext();
        var comment = new OperationDocumentComment
        {
            OperationDocumentId = operationDocumentId,
            Comment = inputComment.Trim(),
            CreatedAt = TimeZoneHelper.GetKoreaTimeNow(),
            AuthorUserName = _currentUserName,
            AuthorName = _currentDisplayName
        };

        context.OperationDocumentComments.Add(comment);
        await context.SaveChangesAsync();

        SetCommentInput(operationDocumentId, string.Empty);
        _statusColor = Color.Success;
        _statusMessage = "댓글이 저장되었습니다.";

        await LoadCommentsAsync();
    }

    private async Task DeleteDocumentAsync(int operationDocumentId)
    {
        if (!_isAdministrator)
        {
            return;
        }

        var confirmed = await MessageService.Confirm("문서와 해당 댓글을 모두 삭제하시겠습니까?", "삭제 확인", options =>
        {
            options.ConfirmButtonText = "삭제";
            options.CancelButtonText = "취소";
        });

        if (!confirmed)
        {
            return;
        }

        using var context = DbFactory.CreateDbContext();
        var document = await context.OperationDocuments
            .FirstOrDefaultAsync(d => d.Id == operationDocumentId);

        if (document is null)
        {
            _statusColor = Color.Danger;
            _statusMessage = "삭제할 문서를 찾을 수 없습니다.";
            return;
        }

        context.OperationDocuments.Remove(document);
        await context.SaveChangesAsync();

        _statusColor = Color.Success;
        _statusMessage = "문서가 삭제되었습니다.";

        await LoadDocumentsAsync();
        await LoadCommentsAsync();
    }

    private async Task DeleteCommentAsync(int commentId)
    {
        if (!_isAdministrator)
        {
            return;
        }

        var confirmed = await MessageService.Confirm("댓글을 삭제하시겠습니까?", "삭제 확인", options =>
        {
            options.ConfirmButtonText = "삭제";
            options.CancelButtonText = "취소";
        });

        if (!confirmed)
        {
            return;
        }

        using var context = DbFactory.CreateDbContext();
        var comment = await context.OperationDocumentComments
            .FirstOrDefaultAsync(c => c.Id == commentId);

        if (comment is null)
        {
            _statusColor = Color.Danger;
            _statusMessage = "삭제할 댓글을 찾을 수 없습니다.";
            return;
        }

        context.OperationDocumentComments.Remove(comment);
        await context.SaveChangesAsync();

        _statusColor = Color.Success;
        _statusMessage = "댓글이 삭제되었습니다.";

        await LoadCommentsAsync();
    }

    private async Task ChangePageAsync(int targetPage)
    {
        var page = Math.Min(Math.Max(targetPage, 1), TotalPages);
        if (page == _currentPage)
        {
            return;
        }

        _currentPage = page;
        await LoadDocumentsAsync();
        await LoadCommentsAsync();
    }

    private async Task LoadDocumentsAsync()
    {
        using var context = DbFactory.CreateDbContext();

        var query = context.OperationDocuments
            .AsNoTracking()
            .Where(d => d.DocumentType == DocumentType);

        _totalDocumentsCount = await query.CountAsync();

        if (_currentPage > TotalPages)
        {
            _currentPage = TotalPages;
        }

        var skip = (_currentPage - 1) * PageSize;

        _documents = await query
            .OrderByDescending(d => d.UpdatedAt)
            .ThenByDescending(d => d.Id)
            .Skip(skip)
            .Take(PageSize)
            .ToListAsync();
    }

    private async Task LoadCommentsAsync()
    {
        if (_documents.Count == 0)
        {
            _comments = new List<OperationDocumentComment>();
            _commentsByDocument = new Dictionary<int, List<OperationDocumentComment>>();
            return;
        }

        using var context = DbFactory.CreateDbContext();
        var operationDocumentIds = _documents.Select(d => d.Id).ToList();

        _comments = await context.OperationDocumentComments
            .AsNoTracking()
            .Where(c => operationDocumentIds.Contains(c.OperationDocumentId))
            .OrderByDescending(c => c.CreatedAt)
            .ToListAsync();

        _commentsByDocument = _comments
            .GroupBy(c => c.OperationDocumentId)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private List<OperationDocumentComment> GetCommentsForDocument(int operationDocumentId)
    {
        return _commentsByDocument.TryGetValue(operationDocumentId, out var comments)
            ? comments
            : new List<OperationDocumentComment>();
    }

    private string GetCommentInput(int operationDocumentId)
    {
        return _commentInputs.TryGetValue(operationDocumentId, out var value) ? value : string.Empty;
    }

    private void SetCommentInput(int operationDocumentId, string value)
    {
        _commentInputs[operationDocumentId] = value;
    }

    private static string FormatAuthor(string? userName, string? name)
    {
        var safeUserName = string.IsNullOrWhiteSpace(userName) ? "Unknown" : userName;
        var safeName = string.IsNullOrWhiteSpace(name) ? "Unknown" : name;
        return $"{safeUserName} ({safeName})";
    }
}
