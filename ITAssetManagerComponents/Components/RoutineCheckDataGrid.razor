@inject IDbContextFactory<ApplicationDbContext> DbFactory

<LoadingIndicator @ref="_loadingIndicator">
    <BaseDataGrid TItem="RoutineCheck"
                  OnUpdateItems=@UpdateItems
                  OnSaveItem="@SaveItems"
                  OnDeleteItem="@DeleteItems">
        <DataGridColumn Field="@nameof(RoutineCheck.Detail)" Caption="점검내용" Editable="true" Width="300px">
            <DisplayTemplate>
                <Div TextOverflow="TextOverflow.Truncate">@context.Detail</Div>
            </DisplayTemplate>
            <EditTemplate>
                <MemoEdit AutoSize="true" Text="@((string)context.CellValue)" TextChanged="@(value => context.CellValue = value)" />
            </EditTemplate>
        </DataGridColumn>
        <DataGridDateColumn Field="@nameof(RoutineCheck.StartDateTime)" Caption="점검시작" Editable="true" InputMode="DateInputMode.DateTime" Width="200px">
            <DisplayTemplate>
                <Div TextOverflow="TextOverflow.Truncate">@context.StartDateTime</Div>
            </DisplayTemplate>
        </DataGridDateColumn>
        <DataGridDateColumn Field="@nameof(RoutineCheck.EndDateTime)" Caption="점검종료" Editable="true" InputMode="DateInputMode.DateTime" Width="200px">
            <DisplayTemplate>
                <Div TextOverflow="TextOverflow.Truncate">@context.EndDateTime</Div>
            </DisplayTemplate>
        </DataGridDateColumn>
    </BaseDataGrid>
</LoadingIndicator>

@code {
    [Parameter, EditorRequired]
    public int CommonAssetId { get; set; }

    private LoadingIndicator _loadingIndicator = null!;

    private async Task<List<RoutineCheck>> UpdateItems()
    {
        using var context = DbFactory.CreateDbContext();
        var items = await context.RoutineChecks
            .Where(x => x.CommonAssetId == CommonAssetId)
            .ToListAsync();
        return items;
    }

    private async Task SaveItems(RoutineCheck item)
    {
        using var context = DbFactory.CreateDbContext();
        if (item.Id == 0)
        {
            item.CommonAssetId = CommonAssetId;
            context.RoutineChecks.Add(item);
        }
        else
        {
            context.RoutineChecks.Update(item);
        }
        await context.SaveChangesAsync();
    }

    private async Task DeleteItems(RoutineCheck item)
    {
        using var context = DbFactory.CreateDbContext();
        context.RoutineChecks.Remove(item);
        await context.SaveChangesAsync();
    }
}
