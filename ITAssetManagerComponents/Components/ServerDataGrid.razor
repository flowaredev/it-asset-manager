@inject IDbContextFactory<ApplicationDbContext> DbFactory
<HeaderTitle Title="@HeaderConstant.ServerTitle" />

<CommonAssetDataGrid OnUpdateItems=@UpdateAssets
                     OnSaveItem=@SaveAsset
                     OnDeleteItem=@DeleteAsset
                     OnShowDetail="@ShowDetailView" />

@if (_modalVisible)
{
    <Modal @bind-Visible="@_modalVisible">
        <ModalContent Centered="true" Scrollable="true" Size="ModalSize.Fullscreen">
            <ModalHeader>
                <ModalTitle>장비사양</ModalTitle>
                <CloseButton Margin="Margin.Is2.FromEnd" />
            </ModalHeader>
            <ModalBody>
                <BaseDataGrid TItem="ServerDevice"
                              OnUpdateItems=@UpdateServerDevices
                              OnSaveItem="@SaveServerDevice"
                              OnDeleteItem="@DeleteServer">
                    <DataGridColumn Field="@nameof(ServerDevice.Manufacturer)" Caption="제조사" Editable="true" Width="200px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.Manufacturer</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.Model)" Caption="모델명" Editable="true" Width="200px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.Model</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.SerialNumber)" Caption="시리얼번호" Editable="true" Width="200px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.SerialNumber</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.NetworkType)" Caption="물리/논리" Editable="true" Width="150px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.NetworkType</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.MountedPhysicalServer)" Caption="탑재물리서버" Editable="true" Width="200px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.MountedPhysicalServer</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.OsType)" Caption="OS종류" Editable="true" Width="150px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.OsType</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.OsVersion)" Caption="OS버전" Editable="true" Width="150px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.OsVersion</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.OsBit)" Caption="OS bit" Editable="true" Width="100px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.OsBit</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridNumericColumn Field="@nameof(ServerDevice.CpuClockGhz)" Caption="CPU클럭(GHz)" Editable="true" Width="150px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.CpuClockGhz</Div>
                        </DisplayTemplate>
                    </DataGridNumericColumn>
                    <DataGridNumericColumn Field="@nameof(ServerDevice.CpuCores)" Caption="CPU코어" Editable="true" Width="120px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.CpuCores</Div>
                        </DisplayTemplate>
                    </DataGridNumericColumn>
                    <DataGridNumericColumn Field="@nameof(ServerDevice.Ram)" Caption="메모리(GB)" Editable="true" Width="150px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.Ram</Div>
                        </DisplayTemplate>
                    </DataGridNumericColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.Disk)" Caption="디스크" Editable="true" Width="150px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.Disk</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.InternalDisk)" Caption="내장디스크" Editable="true" Width="200px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.InternalDisk</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.ExternalDisk)" Caption="외장디스크" Editable="true" Width="200px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.ExternalDisk</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridNumericColumn Field="@nameof(ServerDevice.NicCount)" Caption="NIC개수" Editable="true" Width="120px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.NicCount</Div>
                        </DisplayTemplate>
                    </DataGridNumericColumn>
                    <DataGridNumericColumn Field="@nameof(ServerDevice.HbaCount)" Caption="HBA개수" Editable="true" Width="120px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.HbaCount</Div>
                        </DisplayTemplate>
                    </DataGridNumericColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.IpAddress)" Caption="IP" Editable="true" Width="160px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.IpAddress</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.Rack)" Caption="랙 위치" Editable="true" Width="150px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.Rack</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                    <DataGridNumericColumn Field="@nameof(ServerDevice.UnitSize)" Caption="U" Editable="true" Width="80px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.UnitSize</Div>
                        </DisplayTemplate>
                    </DataGridNumericColumn>
                    <DataGridColumn Field="@nameof(ServerDevice.Notes)" Caption="비고" Editable="true" Width="250px">
                        <DisplayTemplate>
                            <Div TextOverflow="TextOverflow.Truncate">@context.Notes</Div>
                        </DisplayTemplate>
                    </DataGridColumn>
                </BaseDataGrid>
            </ModalBody>
        </ModalContent>
    </Modal>
}

@code {
    private bool _modalVisible;
    private CommonAsset _selectedAsset = new();

    private async Task<List<CommonAsset>> UpdateAssets()
    {
        using var context = DbFactory.CreateDbContext();
        var items = await context.Servers
            .Include(s => s.CommonAsset)
            .Select(s => s.CommonAsset)
            .ToListAsync();
        return items;
    }

    private async Task SaveAsset(CommonAsset asset)
    {
        using var context = DbFactory.CreateDbContext();

        if (asset.Id == 0)
        {
            asset.Server = new Server()
                {
                    CommonAssetId = asset.Id,
                    CommonAsset = asset
                };

            await context.CommonAssets.AddAsync(asset);
        }
        else
        {
            context.CommonAssets.Update(asset);
        }

        await context.SaveChangesAsync();
    }

    private async Task DeleteAsset(CommonAsset asset)
    {
        using var context = DbFactory.CreateDbContext();
        context.CommonAssets.Remove(asset);
        await context.SaveChangesAsync();
    }

    private async Task ShowDetailView(CommonAsset asset)
    {
        _selectedAsset = asset;
        _modalVisible = true;
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task<List<ServerDevice>> UpdateServerDevices()
    {
        using var context = DbFactory.CreateDbContext();
        var items = await context.Servers
            .Where(s => s.CommonAssetId == _selectedAsset.Id)
            .Include(s => s.ServerDevices)
            .SelectMany(s => s.ServerDevices)
            .ToListAsync();
        return items;
    }

    private async Task SaveServerDevice(ServerDevice device)
    {
        using var context = DbFactory.CreateDbContext();

        if (device.Id == 0)
        {
            Debug.Assert(_selectedAsset.Id != 0);

            var server = await context.Servers
                .SingleAsync(s => s.CommonAssetId == _selectedAsset.Id);
            device.ServerId = server.Id;
            context.ServerDevices.Add(device);
        }
        else
        {
            context.ServerDevices.Update(device);
        }

        await context.SaveChangesAsync();
    }

    private async Task DeleteServer(ServerDevice device)
    {
        using var context = DbFactory.CreateDbContext();
        context.ServerDevices.Remove(device);
        await context.SaveChangesAsync();
    }
}

