@inject IDbContextFactory<ApplicationDbContext> DbFactory

<CommonAssetDataGrid Title="서버장비" OnUpdateItems=@UpdateAssets OnSaveItem=@SaveAsset OnDeleteItem=@DeleteAsset OnShowDetailView="@ShowDetailView" />

@if (_modalVisible)
{
    <Modal @bind-Visible="@_modalVisible">
        <ModalContent Centered="true" Scrollable="true" Size="ModalSize.ExtraLarge">
            <ModalHeader>
                <ModalTitle>장비 사양</ModalTitle>
                <CloseButton />
            </ModalHeader>
            <ModalBody>
                <BaseDataGrid TItem="ServerDevice"
                              OnUpdateItems=@UpdateServerDevices
                              OnSaveItem="@SaveServerDevice"
                              OnDeleteItem="@DeleteServer">
                    <DataGridColumn Field="@nameof(ServerDevice.Manufacturer)" Caption="제조사" Editable="true" Width="100%" />
                    <DataGridColumn Field="@nameof(ServerDevice.Model)" Caption="모델명" Editable="true" Width="100%" />
                    <DataGridNumericColumn Field="@nameof(ServerDevice.Cpu)" Caption="CPU(Ghz)" Editable="true" Width="100%" />
                    <DataGridNumericColumn Field="@nameof(ServerDevice.Ram)" Caption="메모리(GB)" Editable="true" Width="100%" />
                    <DataGridNumericColumn Field="@nameof(ServerDevice.Disk)" Caption="디스크(TB)" Editable="true" Width="100%" />
                    <DataGridNumericColumn Field="@nameof(ServerDevice.Rack)" Caption="랙 위치" Editable="true" Width="100%" />
                </BaseDataGrid>
            </ModalBody>
        </ModalContent>
    </Modal>
}

@code {
    private bool _modalVisible;
    private CommonAsset _selectedAsset = new();

    private async Task<List<CommonAsset>> UpdateAssets()
    {
        using var context = DbFactory.CreateDbContext();
        var items = await context.Servers
            .Include(s => s.CommonAsset)
            .Select(s => s.CommonAsset)
            .ToListAsync();
        return items;
    }

    private async Task SaveAsset(CommonAsset asset)
    {
        using var context = DbFactory.CreateDbContext();

        if (asset.Id == 0)
        {
            asset.Server = new Server()
            {
                CommonAssetId = asset.Id,
                CommonAsset = asset
            };

            await context.CommonAssets.AddAsync(asset);
        }
        else
        {
            context.CommonAssets.Update(asset);
        }

        await context.SaveChangesAsync();
    }

    private async Task DeleteAsset(CommonAsset asset)
    {
        using var context = DbFactory.CreateDbContext();
        context.CommonAssets.Remove(asset);
        await context.SaveChangesAsync();
    }

    private async Task ShowDetailView(RowOverlayContext<CommonAsset> context)
    {
        _selectedAsset = context.Item;
        _modalVisible = true;
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task<List<ServerDevice>> UpdateServerDevices()
    {
        using var context = DbFactory.CreateDbContext();
        var items = await context.Servers
            .Where(s => s.CommonAssetId == _selectedAsset.Id)
            .Include(s => s.ServerDevices)
            .SelectMany(s => s.ServerDevices)
            .ToListAsync();
        return items;
    }

    private async Task SaveServerDevice(ServerDevice server)
    {
        using var context = DbFactory.CreateDbContext();

        if (server.Id == 0)
        {
            Debug.Assert(_selectedAsset.Id != 0);
            server.ServerId = _selectedAsset.Server!.Id;
            context.ServerDevices.Add(server);
        }
        else
        {
            context.ServerDevices.Update(server);
        }

        await context.SaveChangesAsync();
    }

    private async Task DeleteServer(ServerDevice server)
    {
        using var context = DbFactory.CreateDbContext();
        context.ServerDevices.Remove(server);
        await context.SaveChangesAsync();
    }
}

