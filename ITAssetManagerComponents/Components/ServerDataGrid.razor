@inject IDbContextFactory<ApplicationDbContext> DbFactory

<HeaderTitle Title="서버" />

<BaseDataGrid TItem="CommonAsset" OnUpdateItems="@UpdateAssets" OnSaveItem="@SaveAsset" OnDeleteItem="@DeleteAsset" OnShowDetailView=@ShowDetailView>
    <DataGridColumn Field="@nameof(CommonAsset.ManagementTag)" Caption="자산번호" Editable="true" Width="100%" />
    <DataGridColumn Field="@nameof(CommonAsset.Name)" Caption="자산명" Editable="true" Width="100%" />
    <DataGridDateColumn Field="@nameof(CommonAsset.ApplyDateTime)" Caption="도입일" Editable="true" InputMode="DateInputMode.DateTime" Width="100%" />
    <DataGridColumn Field="@nameof(CommonAsset.Role)" Caption="업무용도" Editable="true" Width="100%" />
</BaseDataGrid>

@if (_modalVisible)
{
    <Modal @bind-Visible="@_modalVisible">
        <ModalContent Centered="true" Scrollable="true" Size="ModalSize.ExtraLarge">
            <ModalHeader>
                <ModalTitle>장비 사양</ModalTitle>
                <CloseButton />
            </ModalHeader>
            <ModalBody>
                <BaseDataGrid TItem="ServerDevice"
                              OnUpdateItems=@UpdateServers
                              OnSaveItem="@SaveServer"
                              OnDeleteItem="@DeleteServer">
                    <DataGridColumn Field="@nameof(ServerDevice.Manufacturer)" Caption="제조사" Editable="true" Width="100%" />
                    <DataGridColumn Field="@nameof(ServerDevice.Model)" Caption="모델명" Editable="true" Width="100%" />
                    <DataGridNumericColumn Field="@nameof(ServerDevice.Cpu)" Caption="CPU(Ghz)" Editable="true" Width="100%" />
                    <DataGridNumericColumn Field="@nameof(ServerDevice.Ram)" Caption="Ram(GB)" Editable="true" Width="100%" />
                    <DataGridNumericColumn Field="@nameof(ServerDevice.Disk)" Caption="Disk(TB)" Editable="true" Width="100%" />
                </BaseDataGrid>
            </ModalBody>
        </ModalContent>
    </Modal>
}

@code {
    private bool _modalVisible;
    private CommonAsset _selectedAsset = new();

    private async Task<List<CommonAsset>> UpdateAssets()
    {
        using var context = DbFactory.CreateDbContext();
        var items = await context.CommonAssets
            .ToListAsync();
        return items;
    }

    private async Task SaveAsset(CommonAsset asset)
    {
        using var context = DbFactory.CreateDbContext();

        if (asset.Id == 0)
        {
            await context.CommonAssets.AddAsync(asset);
        }
        else
        {
            context.CommonAssets.Update(asset);
        }

        await context.SaveChangesAsync();
    }

    private async Task DeleteAsset(CommonAsset asset)
    {
        using var context = DbFactory.CreateDbContext();
        context.CommonAssets.Remove(asset);
        await context.SaveChangesAsync();
    }

    private async Task ShowDetailView(RowOverlayContext<CommonAsset> context)
    {
        _selectedAsset = context.Item;
        _modalVisible = true;
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task<List<ServerDevice>> UpdateServers()
    {
        using var context = DbFactory.CreateDbContext();
        var items = await context.ServerDevices
            .Where(s => s.CommonAssetId == _selectedAsset.Id)
            .ToListAsync();
        return items;
    }

    private async Task SaveServer(ServerDevice server)
    {
        using var context = DbFactory.CreateDbContext();

        if (server.Id == 0)
        {
            Debug.Assert(_selectedAsset.Id != 0);
            server.CommonAssetId = _selectedAsset.Id;
            context.ServerDevices.Add(server);
        }
        else
        {
            context.ServerDevices.Update(server);
        }

        await context.SaveChangesAsync();
    }

    private async Task DeleteServer(ServerDevice server)
    {
        using var context = DbFactory.CreateDbContext();
        context.ServerDevices.Remove(server);
        await context.SaveChangesAsync();
    }
}

