@using Blazorise.DataGrid.Utils
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Logging
@using Blazorise.Localization
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject ILogger<AdminUserManagement> Logger
@inject ITextLocalizer<DataGrid<UserViewModel>> DataGridLocalizer

<HeaderTitle Title="@HeaderConstant.UserManagementTitle" />

<Container Fluid>
    <Row>
        <Column>
            <Card>
                <CardHeader>
                    <CardTitle>@HeaderConstant.UserManagementTitle</CardTitle>
                </CardHeader>
                <CardBody>
                    <DataGrid @ref=dataGridRef
                              TItem="UserViewModel"
                              Data="@users"
                              ReadData="@OnReadData"
                              TotalItems="@totalUsers"
                              ShowPager="true"
                              Responsive="true"
                              Sortable="true"
                              SortMode="DataGridSortMode.Single"
                              Filterable="true"
                              FilterMode="DataGridFilterMode.Menu"
                              ShowPageSizes="true">
                        <DataGridColumns>
                            <DataGridColumn Field="@nameof(UserViewModel.Email)" Caption="이메일">
                                <DisplayTemplate>
                                    @context.Email
                                </DisplayTemplate>
                            </DataGridColumn>
                            <DataGridColumn Field="@nameof(UserViewModel.Name)" Caption="이름">
                                <DisplayTemplate>
                                    @context.Name
                                </DisplayTemplate>
                            </DataGridColumn>
                            <DataGridColumn Field="@nameof(UserViewModel.Department)" Caption="부서">
                                <DisplayTemplate>
                                    @context.Department
                                </DisplayTemplate>
                            </DataGridColumn>
                            <DataGridColumn Field="@nameof(UserViewModel.PhoneNumber)" Caption="전화번호">
                                <DisplayTemplate>
                                    @context.PhoneNumber
                                </DisplayTemplate>
                            </DataGridColumn>
                            <DataGridColumn Field="@nameof(UserViewModel.Role)" Caption="역할">
                                <DisplayTemplate>
                                    <Badge Color="@GetRoleBadgeColor(context.Role)">@context.Role</Badge>
                                </DisplayTemplate>
                            </DataGridColumn>
                            <DataGridColumn Field="@nameof(UserViewModel.Id)" Caption="작업" Sortable="false" Filterable="false">
                                <DisplayTemplate>
                                    <Buttons Size="Size.Small">
                                        <Button Color="Color.Primary" Size="Size.Small"
                                                Clicked="@(() => OpenEditRoleModal(context))">
                                            <Icon Name="IconName.Edit" /> 역할 변경
                                        </Button>
                                        <Button Color="Color.Warning" Size="Size.Small"
                                                Clicked="@(() => OpenChangePasswordModal(context))">
                                            <Icon Name="IconName.Key" /> 비밀번호 변경
                                        </Button>
                                        <Button Color="Color.Danger" Size="Size.Small"
                                                Clicked="@(() => DeleteUser(context))"
                                                Disabled="@(context.Role == RoleConstants.Administrator)">
                                            <Icon Name="IconName.Delete" /> 삭제
                                        </Button>
                                    </Buttons>
                                </DisplayTemplate>
                            </DataGridColumn>
                        </DataGridColumns>

                        <PageButtonTemplate>
                            <Span TextColor="TextColor.Light">
                                @context.PageNumber
                            </Span>
                        </PageButtonTemplate>
                        <NextPageButtonTemplate><Icon Name="IconName.StepForward" TextColor="TextColor.Primary" /></NextPageButtonTemplate>
                        <PreviousPageButtonTemplate><Icon Name="IconName.StepBackward" TextColor="TextColor.Primary" /></PreviousPageButtonTemplate>
                        <LastPageButtonTemplate><Icon Name="IconName.Forward" TextColor="TextColor.Primary" /></LastPageButtonTemplate>
                        <FirstPageButtonTemplate><Icon Name="IconName.Backward" TextColor="TextColor.Primary" /></FirstPageButtonTemplate>
                        <ItemsPerPageTemplate></ItemsPerPageTemplate>
                        <!-- 페이지네이션 정보 표시 템플릿 커스터마이징 -->
                        <TotalItemsTemplate>
                            <Small TextColor="TextColor.Muted">
                                @{
                                    var startItem = (context.CurrentPage - 1) * context.CurrentPageSize + 1;
                                    var endItem = context.CurrentPage * context.CurrentPageSize;
                                }
                                @startItem - @endItem / @context.TotalItems 항목
                            </Small>
                        </TotalItemsTemplate>

                        <!-- 페이지 사이즈 선택 템플릿 -->
                        <PageSizesTemplate>
                            <Select TextColor="TextColor.Primary" @bind-SelectedValue="@context.CurrentPageSize">
                                @foreach (var curPageSize in context.PageSizes)
                                {
                                    <SelectItem Value="@curPageSize">@curPageSize</SelectItem>
                                }
                            </Select>
                        </PageSizesTemplate>
                    </DataGrid>
                </CardBody>
            </Card>
        </Column>
    </Row>
</Container>

<!-- Edit Role Modal -->
<Modal @ref="editRoleModalRef">
    <ModalContent Centered="true">
        <ModalHeader>
            <ModalTitle>역할 변경</ModalTitle>
            <CloseButton />
        </ModalHeader>
        <ModalBody>
            @if (selectedUser != null)
            {
                <Field>
                    <FieldLabel>사용자: @selectedUser.Email</FieldLabel>
                </Field>
                <Field>
                    <FieldLabel>현재 역할: @selectedUser.Role</FieldLabel>
                </Field>
                <Field>
                    <FieldLabel>새 역할</FieldLabel>
                    <Select @bind-SelectedValue="newRole">
                        <SelectItem Value="@RoleConstants.Administrator">Administrator</SelectItem>
                        <SelectItem Value="@RoleConstants.User">User</SelectItem>
                        <SelectItem Value="@RoleConstants.None">None</SelectItem>
                    </Select>
                </Field>
            }
        </ModalBody>
        <ModalFooter>
            <Button Color="Color.Secondary" Clicked="@HideEditRoleModal">취소</Button>
            <Button Color="Color.Primary" Clicked="@UpdateUserRole">저장</Button>
        </ModalFooter>
    </ModalContent>
</Modal>

<!-- Change Password Modal -->
<Modal @ref="changePasswordModalRef">
    <ModalContent Centered="true">
        <ModalHeader>
            <ModalTitle>비밀번호 변경</ModalTitle>
            <CloseButton />
        </ModalHeader>
        <ModalBody>
            @if (selectedUser != null)
            {
                @if (!string.IsNullOrEmpty(passwordChangeMessage))
                {
                    <Alert Color="@(passwordChangeMessage.Contains("성공") ? Color.Success : Color.Danger)" Visible>
                        <AlertDescription>@passwordChangeMessage</AlertDescription>
                    </Alert>
                }
                
                <Field>
                    <FieldLabel>사용자: @selectedUser.Email</FieldLabel>
                </Field>
                
                <Field>
                    <FieldLabel>새 비밀번호</FieldLabel>
                    <TextEdit @bind-Text="newPassword" 
                              Role="TextRole.Password" 
                              Placeholder="새 비밀번호를 입력하세요" />
                </Field>
                
                <Field>
                    <FieldLabel>비밀번호 확인</FieldLabel>
                    <TextEdit @bind-Text="confirmPassword" 
                              Role="TextRole.Password" 
                              Placeholder="비밀번호를 다시 입력하세요" />
                </Field>
            }
        </ModalBody>
        <ModalFooter>
            <Button Color="Color.Secondary" Clicked="@HideChangePasswordModal">취소</Button>
            <Button Color="Color.Warning" Clicked="@ChangeUserPassword">비밀번호 변경</Button>
        </ModalFooter>
    </ModalContent>
</Modal>

<!-- Delete Confirmation Modal -->
<Modal @ref="deleteConfirmModalRef">
    <ModalContent Centered="true">
        <ModalHeader>
            <ModalTitle>사용자 삭제 확인</ModalTitle>
            <CloseButton />
        </ModalHeader>
        <ModalBody>
            @if (selectedUser != null)
            {
                <Alert Color="Color.Danger" Visible>
                    <AlertMessage>경고!</AlertMessage>
                    <AlertDescription>
                        사용자 <strong>@selectedUser.Email</strong>을(를) 영구적으로 삭제하시겠습니까?
                        이 작업은 되돌릴 수 없습니다.
                    </AlertDescription>
                </Alert>
            }
        </ModalBody>
        <ModalFooter>
            <Button Color="Color.Secondary" Clicked="@HideDeleteConfirmModal">취소</Button>
            <Button Color="Color.Danger" Clicked="@ConfirmDeleteUser">삭제</Button>
        </ModalFooter>
    </ModalContent>
</Modal>

@code {
    private List<UserViewModel> users = new();
    private List<UserViewModel> usersSource = new();
    private int totalUsers = 0;
    private UserViewModel? selectedUser;
    private string newRole = "";
    private string? passwordChangeMessage;
    private string newPassword = "";
    private string confirmPassword = "";

    private Modal editRoleModalRef = default!;
    private Modal changePasswordModalRef = default!;
    private Modal deleteConfirmModalRef = default!;
    private DataGrid<UserViewModel> dataGridRef = default!;

    protected override async Task OnInitializedAsync()
    {
        // DataGrid 한글 localization 설정
        DataGridLocalizer.AddLanguageResource(DataGridLocalizationHelper.GetKoreanDataGridResource());

        await LoadUser();

        await base.OnInitializedAsync();
    }

    private async Task LoadUser()
    {
        usersSource = new List<UserViewModel>();

        var allUsers = UserManager.Users.ToList();

        foreach (var user in allUsers)
        {
            var roles = await UserManager.GetRolesAsync(user);
            var role = roles.FirstOrDefault() ?? RoleConstants.None;

            usersSource.Add(new UserViewModel
            {
                Id = user.Id,
                Email = user.Email ?? "",
                UserName = user.UserName ?? "",
                Name = user.Name ?? "",
                Department = user.Department ?? "",
                PhoneNumber = user.PhoneNumber ?? "",
                Role = role,
                EmailConfirmed = user.EmailConfirmed
            });
        }
    }

    private async Task OnReadData(DataGridReadDataEventArgs<UserViewModel> e)
    {
        if (!e.CancellationToken.IsCancellationRequested)
        {
            var query = usersSource.AsQueryable().ApplyDataGridSort(e.Columns).ApplyDataGridSearch(e.Columns);

            if (dataGridRef.CustomFilter is not null)
                query = query.Where(item => item != null && dataGridRef.CustomFilter(item));

            var response = new List<UserViewModel>();

            if (e.ReadDataMode is DataGridReadDataMode.Virtualize)
                response = query.ApplyDataGridPaging(e.VirtualizeOffset + 1, e.VirtualizeCount).ToList();
            else if (e.ReadDataMode is DataGridReadDataMode.Paging)
                response = query.ApplyDataGridPaging(e.Page, e.PageSize).ToList();
            else
                throw new Exception("Unhandled ReadDataMode");

            await Task.Delay(Random.Shared.Next(100));

            if (!e.CancellationToken.IsCancellationRequested)
            {
                totalUsers = query.Count();
                users = response;
            }
        }
    }

    private void OpenEditRoleModal(UserViewModel user)
    {
        selectedUser = user;
        newRole = user.Role;
        editRoleModalRef.Show();
    }

    private void HideEditRoleModal()
    {
        editRoleModalRef.Hide();
        selectedUser = null;
        newRole = "";
    }

    private void OpenChangePasswordModal(UserViewModel user)
    {
        selectedUser = user;
        newPassword = "";
        confirmPassword = "";
        passwordChangeMessage = null;
        changePasswordModalRef.Show();
    }

    private void HideChangePasswordModal()
    {
        changePasswordModalRef.Hide();
        selectedUser = null;
        newPassword = "";
        confirmPassword = "";
        passwordChangeMessage = null;
    }

    private async Task ChangeUserPassword()
    {
        if (selectedUser == null) return;

        // Manual validation check
        if (string.IsNullOrWhiteSpace(newPassword))
        {
            passwordChangeMessage = "새 비밀번호는 필수입니다.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            passwordChangeMessage = "비밀번호와 비밀번호 확인이 일치하지 않습니다.";
            return;
        }

        if (newPassword.Length < 6)
        {
            passwordChangeMessage = "비밀번호는 최소 6자 이상이어야 합니다.";
            return;
        }

        try
        {
            var user = await UserManager.FindByIdAsync(selectedUser.Id);
            if (user == null)
            {
                passwordChangeMessage = "사용자를 찾을 수 없습니다.";
                return;
            }

            // Remove current password and set new one
            var token = await UserManager.GeneratePasswordResetTokenAsync(user);
            var result = await UserManager.ResetPasswordAsync(user, token, newPassword);

            if (result.Succeeded)
            {
                Logger.LogInformation("Admin changed password for user {Email}", user.Email);
                passwordChangeMessage = "비밀번호가 성공적으로 변경되었습니다.";
                
                // Auto-hide modal after 2 seconds
                await Task.Delay(2000);
                HideChangePasswordModal();
            }
            else
            {
                var errors = string.Join(", ", result.Errors.Select(e => e.Description));
                passwordChangeMessage = $"오류: {errors}";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error changing user password");
            passwordChangeMessage = "비밀번호 변경 중 오류가 발생했습니다.";
        }
    }

    private async Task UpdateUserRole()
    {
        if (selectedUser == null) return;

        try
        {
            var user = await UserManager.FindByIdAsync(selectedUser.Id);
            if (user == null) return;

            // Remove user from all roles
            var currentRoles = await UserManager.GetRolesAsync(user);
            if (currentRoles.Any())
            {
                await UserManager.RemoveFromRolesAsync(user, currentRoles);
            }

            // Add user to new role
            await UserManager.AddToRoleAsync(user, newRole);

            Logger.LogInformation("User {Email} role changed to {Role}", user.Email, newRole);

            HideEditRoleModal();
            // Reload data grid
            await LoadUser();
            await dataGridRef.Reload();

        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating user role");
        }
    }

    private void DeleteUser(UserViewModel user)
    {
        selectedUser = user;
        deleteConfirmModalRef.Show();
    }

    private void HideDeleteConfirmModal()
    {
        deleteConfirmModalRef.Hide();
        selectedUser = null;
    }

    private async Task ConfirmDeleteUser()
    {
        if (selectedUser == null) return;

        try
        {
            var user = await UserManager.FindByIdAsync(selectedUser.Id);
            if (user == null) return;

            var result = await UserManager.DeleteAsync(user);
            if (result.Succeeded)
            {
                Logger.LogInformation("User {Email} deleted", user.Email);
                await LoadUser();
                await dataGridRef.Reload();
            }
            else
            {
                Logger.LogError("Failed to delete user {Email}: {Errors}",
                    user.Email, string.Join(", ", result.Errors.Select(e => e.Description)));
            }

            HideDeleteConfirmModal();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting user");
        }
    }

    private Color GetRoleBadgeColor(string role)
    {
        return role switch
        {
            RoleConstants.Administrator => Color.Danger,
            RoleConstants.User => Color.Success,
            RoleConstants.None => Color.Secondary,
            _ => Color.Light
        };
    }

    public class UserViewModel
    {
        public string Id { get; set; } = "";
        public string Email { get; set; } = "";
        public string UserName { get; set; } = "";
        public string Name { get; set; } = ""; // 추가: 사용자 이름
        public string Department { get; set; } = ""; // 추가: 부서
        public string PhoneNumber { get; set; } = "";
        public string Role { get; set; } = "";
        public bool EmailConfirmed { get; set; }
    }
}