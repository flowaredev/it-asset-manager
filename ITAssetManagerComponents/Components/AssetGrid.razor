@implements IDisposable
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<DataGrid TItem="CommonAsset"
          Data="@_assets"
          ReadData="@OnReadData"
          TotalItems="@_totalAssets"
          @bind-SelectedRow="@_selectedAsset"
          RowStyling='(x, y) => y.Style = "height: 50px;"'
          Virtualize="true"
          VirtualizeOptions="@(new() { DataGridHeight = "100%", DataGridMaxHeight = "100%" })"
          Responsive="true">
    <DataGridColumns>
        <DataGridCommandColumn />
        <DataGridColumn Field="@nameof(CommonAsset.ManagementTag)" Caption="자산번호" Editable="true" />
        <DataGridColumn Field="@nameof(CommonAsset.AssetTag)" Caption="자산분류" Editable="true" />
        <DataGridColumn Field="@nameof(CommonAsset.Name)" Caption="자산명" Editable="true" />
        <DataGridColumn Field="@nameof(CommonAsset.Role)" Caption="업무용도" Editable="true" />
        <DataGridColumn Field="@nameof(CommonAsset.Manufacturer)" Caption="제조사" Editable="true" />
        <DataGridColumn Field="@nameof(CommonAsset.Model)" Caption="모델명" Editable="true" />
    </DataGridColumns>
    <EmptyTemplate>
        <Alert Color="Color.Info" Visible="true">
            <AlertMessage>등록된 자산이 없습니다.</AlertMessage>
        </Alert>
    </EmptyTemplate>
</DataGrid>

@code {
    private ObservableCollection<CommonAsset>? _assets;
    private CommonAsset? _selectedAsset;
    private ApplicationDbContext? _context { get; set; }
    private int _totalAssets;

    protected override async Task OnInitializedAsync()
    {
        _context = DbFactory.CreateDbContext();
        await base.OnInitializedAsync();
    }

    private async Task OnReadData(DataGridReadDataEventArgs<CommonAsset> e)
    {
        if (!e.CancellationToken.IsCancellationRequested)
        {
            List<CommonAsset> response;

            if (e.ReadDataMode is DataGridReadDataMode.Virtualize)
                response = await _context!.CommonAssets
                    .Skip(e.VirtualizeOffset)
                    .Take(e.VirtualizeCount)
                    .ToListAsync();
            else if (e.ReadDataMode is DataGridReadDataMode.Paging)
                response = await _context!.CommonAssets
                    .Skip((e.Page - 1) * e.PageSize)
                    .Take(e.PageSize)
                    .ToListAsync();
            else
                throw new Exception("Unhandled ReadDataMode");

            if (!e.CancellationToken.IsCancellationRequested)
            {
                _totalAssets = await _context!.CommonAssets.CountAsync();
                _assets = new ObservableCollection<CommonAsset>(response);
            }
        }
    }

    public void Dispose()
    {
        _context?.Dispose();
    }
}
