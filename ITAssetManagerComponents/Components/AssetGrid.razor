@inject IDbContextFactory<ApplicationDbContext> DbFactory

<BaseDataGrid TItem="CommonAsset" OnUpdateItems="@UpdateItems" OnSaveItem="SaveItem">
    <DataGridColumn Field="@nameof(CommonAsset.ManagementTag)" Caption="자산번호" Editable="true" />
    <DataGridColumn Field="@nameof(CommonAsset.AssetTag)" Caption="자산분류" Editable="true" />
    <DataGridColumn Field="@nameof(CommonAsset.Name)" Caption="자산명" Editable="true" />
    <DataGridColumn Field="@nameof(CommonAsset.Role)" Caption="업무용도" Editable="true" />
    <DataGridColumn Field="@nameof(CommonAsset.Manufacturer)" Caption="제조사" Editable="true" />
    <DataGridColumn Field="@nameof(CommonAsset.Model)" Caption="모델명" Editable="true" />
    <DataGridDateColumn Field="@nameof(CommonAsset.ApplyDateTime)" Caption="도입일" Editable="true" DisplayFormat="{0:yyyy-MM-dd}" />
</BaseDataGrid>

@code {

    private UpdateItemsEventResult<CommonAsset> UpdateItems(UpdateItemsEventArgs args)
    {
        using var context = DbFactory.CreateDbContext();
        var items = context.CommonAssets
            .OrderByDescending(x => x.Id)
            .Skip(args.SkipCount)
            .Take(args.TakeCount)
            .ToList();

        return new UpdateItemsEventResult<CommonAsset>
            {
                TotalItems = context.CommonAssets.Count(),
                Items = items
            };
    }

    private async Task SaveItem(SaveItemEventArgs<CommonAsset> args)
    {
        Debug.Assert(args.Item.Manufacturer != null);

        using var context = DbFactory.CreateDbContext();

        if (args.Item.Id == 0)
        {
            args.Item.Id = 0;
            await context.CommonAssets.AddAsync(args.Item);
        }
        else
        {
            context.CommonAssets.Update(args.Item);
        }

        await context.SaveChangesAsync();
    }
}

